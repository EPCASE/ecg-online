# Clé API OpenAI (obligatoire pour la correction GPT)
OPENAI_API_KEY=sk-...

# Modèle de correction (optionnel, défaut : gpt-4o-2024-08-06)
# ECG_GRADER_MODEL=gpt-4o-2024-08-06

# Port local (optionnel, défaut : 5000)
# PORT=5000

# ── Backend de correction (optionnel) ────────────────────────────────
# "neuro" (défaut) = pipeline neurosymbolique V3 avec repli GPT-4o.
# "gpt"            = grader GPT-4o direct.
# ECG_GRADER_BACKEND=neuro

# ── Anonymisation des cas (optionnel, défaut : activée) ───────────────
# Le titre d'un cas EST le diagnostic ; anonymisé, la barre latérale
# affiche « Cas 1 », « Cas 2 »… et les familles sont masquées.
# Mettre à 0 pour afficher les vrais titres (mode enseignant/révision).
# ECG_ANONYMIZE=1

# ── Protection du barème / curation (optionnel mais RECOMMANDÉ en prod) ─
# Le réglage du barème (page /curation) est réservé à l'enseignant.
#   • Vide (défaut)  -> /curation ouvert (pratique en local).
#   • Défini         -> /curation et l'édition du barème exigent le jeton.
#     Accès enseignant :  https://…/curation?key=VOTRE_SECRET
#     Un étudiant qui tape /curation sans le jeton reçoit un 403.
# CURATION_TOKEN=choisir-un-secret-long-et-aleatoire

# ── Recueil des réponses dans Google Sheets (optionnel) ───────────────
# Désactivé tant que GOOGLE_SHEET_ID + GOOGLE_SHEETS_CREDENTIALS ne sont
# pas fournis. Voir ECG collector / SETUP_GOOGLE_SHEETS.md pour créer le
# compte de service et partager la feuille avec son adresse client_email.
# ECG_COLLECT=1
# GOOGLE_SHEET_ID=1AbCdEf...          # ID de la feuille (dans son URL)
# GOOGLE_SHEETS_CREDENTIALS={"type":"service_account", ...}   # JSON inline
# GOOGLE_SHEETS_CREDENTIALS_FILE=/chemin/service_account.json  # ou fichier
